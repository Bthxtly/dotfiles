[pyprland]
plugins = [
  "magnify",
  "scratchpads"
]

[scratchpads.up]
animation = "fromTop"
command = "kitty --class kitty-tm"
class = "kitty-tm"
size = "75% 75%"
max_size = "1920px 100%"
margin = 50

[scratchpads.down]
animation = "fromRight"
command = "kitty --class kitty-fm -e yazi"
class = "kitty-fm"
size = "75% 75%"
max_size = "1920px 100%"
margin = 20
